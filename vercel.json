{
  "version": 2,
  "rewrites": [
    { "source": "/webhook", "destination": "/api/index.js" },
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/client/index.html", "continue": true },
    { "source": "/(.*)", "destination": "/client/$1" }
  ]
}
